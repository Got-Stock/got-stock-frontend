# ===========================================
# GOT-STOCK FRONTEND (Version B) — ENV TEMPLATE
# Generated from the actual code in this repo (src/**), NOT from Version A.
# Copy to .env.local (local dev) or set in your host's env (production).
# NEVER commit the real .env.local with secrets.
# ===========================================

# Root URL of the FastAPI backend — NO trailing /api.
# The code appends "/api" itself (e.g. `${REACT_APP_BACKEND_URL}/api/...`),
# so including /api here would produce broken "/api/api" requests.
#   Local dev:   http://localhost:8000
#   Production:  https://your-backend-host.example.com
REACT_APP_BACKEND_URL=http://localhost:8000

# NOTE: This frontend talks ONLY to the FastAPI backend above. It does NOT
# create a Supabase client directly, so the REACT_APP_SUPABASE_* and
# REACT_APP_STRIPE_* vars from Version A's template are NOT used here.
